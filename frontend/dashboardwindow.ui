   <string notr="true">QWidget#centralwidget {
    background-color: #1C2128;
}

QPushButton {
    background-color: transparent;
    color: #8B949E;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 15px;
    font-weight: bold;
    text-align: left;
    padding: 12px 20px;
    border: none;
    border-radius: 0px;
}

QPushButton:hover {
    background-color: #2D333B;
    color: #FFFFFF;
    border-left: 4px solid #0056A4;
}

QTableWidget {
    background-color: #1C2128;
    color: #FFFFFF;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 13px;
    border: none;
    gridline-color: #373E47;
}

QHeaderView::section {
    background-color: #22272E;
    color: #8B949E;
    font-weight: bold;
    padding: 8px;
    border: 1px solid #373E47;
}

/* --- PROFILE --- */

QLabel#lbl_avatar {
