  <property name="styleSheet">
   <string notr="true">QWidget#centralwidget {
    background-color: #1C2128;
}

QPushButton {
    background-color: transparent;
    color: #8B949E;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 15px;
    font-weight: bold;
    text-align: left;
    padding: 12px 20px;
    border: none;
    border-radius: 0px;
}

QPushButton:hover {
    background-color: #2D333B;
    color: #FFFFFF;
    border-left: 4px solid #0056A4;
}

QTableWidget {
    background-color: #1C2128;
    color: #FFFFFF;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 13px;
    border: none;
    gridline-color: #373E47;
}

QHeaderView::section {
    background-color: #22272E;
    color: #8B949E;
    font-weight: bold;
    padding: 8px;
    border: 1px solid #373E47;
}

/* --- PROFILE --- */

QLabel#lbl_avatar {
    background-color: #F0F3F6;
    border: none;
    border-radius: 8px; 
    padding: 4px;
}

#page_profile QLabel {
    color: #8B949E;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 14px;
    font-weight: normal;
    font-style: normal;
}

QLabel#lbl_name {
    color: #FFFFFF;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 22px;
    font-weight: bold;
}

/* --- SCHEDULE --- */

QComboBox {
    background-color: #22272E;
    color: #FFFFFF;
    border: 1px solid #373E47;
    border-radius: 6px;
    padding: 4px 12px;
    min-height: 32px; 
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 14px;
}

QComboBox:hover {
    border: 1px solid #8B949E;
}

QComboBox:!enabled, QComboBox::drop-down:!enabled {
    color: #8B949E;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 30px;
    border-left: 1px solid #373E47; 
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
}

QComboBox::down-arrow {
	image: url(:/assets/arrow.svg);
	width: 16px;
	height: 16px;
}

QComboBox::down-arrow:on {
    top: 1px;
}

QComboBox QAbstractItemView {
    background-color: #22272E;
    color: #FFFFFF;
    border: 1px solid #373E47;
    border-radius: 4px;
    selection-background-color: #0056A4;
    selection-color: #FFFFFF;
    outline: none; 
    padding: 4px;
}

/* --- INFO --- */

QLabel#lbl_info_text {
    padding: 20px;
    line-height: 1.6;
    color: #C9D1D9;
    font-size: 14px;
}

QGroupBox {
    border: 1px solid #30363D;
    border-radius: 10px;
    background-color: #161B22;
    margin-top: 15px;
    font-size: 14px;
    color: #FFFFFF;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 10px;
    padding: 0 5px;
}

QLabel#lbl_title {
    font-size: 32px;
    font-weight: 600;
    color: #FFFFFF;
    margin-top: 20px;
    margin-bottom: 5px;
}

QLabel#lbl_slogan {
    font-size: 16px;
    font-style: italic;
    color: #58A6FF;
    margin-bottom: 30px;
}

/* --- DORM --- */

QLabel#label_7 {
    font-size: 24px;
    font-weight: bold;
    color: #FFFFFF;
    margin-bottom: 10px;
    padding-top: 20px;
}

QLabel#label_8 {
    font-size: 15px;
    color: #8B949E;
    line-height: 1.5;
    padding: 10px;
    background-color: #161B22;
    border-radius: 8px;
    border: 1px solid #30363D;
}</string>
